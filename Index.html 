<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HACYBERGLOBALTECH™ | BotGrabber</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>
body {margin:0;font-family:Inter;background:#05070d;color:#fff;}
.container {max-width:1100px;margin:auto;padding:20px;}
.hero {text-align:center;padding:100px 20px;}

.logo {color:#00f0ff;font-size:28px;text-shadow:0 0 20px #00f0ff;}

.btn {padding:10px 20px;margin:10px;border-radius:8px;cursor:pointer;}
.btn-primary {background:linear-gradient(90deg,#00f0ff,#7a5cff);color:#000;}
.btn-secondary {border:1px solid #333;}

.grid {display:grid;gap:20px;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));}
.card {background:#0b0f1a;padding:20px;border-radius:10px;cursor:pointer;}
.card.active {border:1px solid #00f0ff;}

.status {padding:4px 8px;border-radius:6px;font-size:12px;}
.awaiting_payment {background:orange;color:#000;}
.payment_requested {background:#ffcc00;color:#000;}
.approved {background:#00ff9d;color:#000;}
.rejected {background:red;}

.table {width:100%;margin-top:20px;border-collapse:collapse;}
.table td,.table th {border:1px solid #222;padding:10px;}

.dashboard {display:none;}
.active {display:block;}

.modal {
  display:none;
  position:fixed;
  width:100%;height:100%;
  top:0;left:0;
  background:rgba(0,0,0,0.8);
  justify-content:center;
  align-items:center;
}

.modal-content {background:#0b0f1a;padding:20px;border-radius:10px;text-align:center;}
.modal img {width:180px;}
</style>
</head>

<body>

<section class="hero">
  <div class="logo">⚡ HACYBERGLOBALTECH™</div>
  <h1>Automate Everything</h1>

  <button class="btn btn-primary" onclick="scrollToPricing()">Activate</button>
  <button class="btn btn-secondary" onclick="toggleDashboard()">Dashboard</button>
</section>

<section id="pricing" class="container">
  <h2>Select Plan</h2>

  <div class="grid">
    <div class="card" onclick="selectPlan(this,'Bot Activation $135.50')">Bot Activation</div>
    <div class="card" onclick="selectPlan(this,'Renewal $91.99')">Renewal</div>
    <div class="card" onclick="selectPlan(this,'2FA $75.40')">2FA</div>
  </div>

  <button class="btn btn-primary" onclick="createRequest()">Create Request</button>
</section>

<section class="container">
  <h2>Payment</h2>

  <p style="color:#8b93a7;">
    Payment methods are assigned by admin after request.<br><br>
    Supported methods:<br>
    Zelle • Apple Pay • Cash App • Venmo • PayPal • Chime • Gift Card / Coupon • Crypto
  </p>

  <p style="color:#00f0ff;">
    ⚠️ Request your payment method via Telegram
  </p>

  <a id="telegramBtn" class="btn btn-primary" target="_blank">
    📲 Contact Admin
  </a>

  <button class="btn btn-secondary" onclick="openPayment()">💳 Pay Crypto</button>

  <br><br>

  <input type="file" id="proofUpload">
  <button class="btn btn-primary" onclick="uploadProof()">Upload Payment Proof</button>

  <p style="font-size:12px;color:#8b93a7;">
    Upload screenshot after payment for admin verification
  </p>
</section>

<section id="dashboard" class="dashboard container">
  <h2>Dashboard</h2>

  <input id="pass" placeholder="Admin Password">
  <button onclick="login()">Login</button>

  <div id="admin" style="display:none">
    <table class="table" id="adminTable"></table>
  </div>

  <table class="table" id="userTable"></table>
</section>

<!-- CRYPTO MODAL -->
<div id="paymentModal" class="modal">
  <div class="modal-content">
    <h3>Crypto Payment</h3>
    <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=YOUR_WALLET">
    <p id="wallet">YOUR_WALLET</p>
    <button onclick="copyWallet()">Copy</button>
    <button onclick="closePayment()">Close</button>
  </div>
</div>

<script>
let requests = JSON.parse(localStorage.getItem("req")) || [];
let selectedPlan=null;

function save(){localStorage.setItem("req",JSON.stringify(requests));}

function selectPlan(el,plan){
  document.querySelectorAll(".card").forEach(c=>c.classList.remove("active"));
  el.classList.add("active");
  selectedPlan=plan;
}

function createRequest(){
  if(!selectedPlan)return alert("Select plan");

  let id=Date.now();

  requests.push({
    id,
    plan:selectedPlan,
    status:"awaiting_payment",
    proof:null
  });

  save(); render();
}

function uploadProof(){
  let file=document.getElementById("proofUpload").files[0];
  if(!file)return alert("Upload file");

  let reader=new FileReader();
  reader.onload=function(){
    requests[requests.length-1].proof=reader.result;
    save();
    render();
    alert("Proof uploaded");
  };
  reader.readAsDataURL(file);
}

function login(){
  if(document.getElementById("pass").value==="admin123"){
    document.getElementById("admin").style.display="block";
  }
}

function requestPayment(id){
  requests=requests.map(r=>r.id===id?{...r,status:"payment_requested"}:r);
  save(); render();
}

function confirmPayment(id){
  let r=requests.find(r=>r.id===id);

  if(r.status!=="payment_requested") return alert("Request payment first");
  if(!r.proof) return alert("No proof uploaded");

  requests=requests.map(x=>x.id===id?{...x,status:"approved"}:x);
  save(); render();

  alert("Payment confirmed");
}

function reject(id){
  requests=requests.map(r=>r.id===id?{...r,status:"rejected"}:r);
  save(); render();
}

function render(){
  let user=`<tr><th>ID</th><th>Plan</th><th>Status</th></tr>`;
  let admin=`<tr><th>ID</th><th>Plan</th><th>Status</th><th>Proof</th><th>Action</th></tr>`;

  requests.forEach(r=>{
    user+=`<tr>
      <td>${r.id}</td>
      <td>${r.plan}</td>
      <td>${r.status}</td>
    </tr>`;

    admin+=`<tr>
      <td>${r.id}</td>
      <td>${r.plan}</td>
      <td>${r.status}</td>
      <td>${r.proof ? `<img src="${r.proof}" width="50">` : "-"}</td>
      <td>
        <button onclick="requestPayment(${r.id})">💳</button>
        <button onclick="confirmPayment(${r.id})">✅</button>
        <button onclick="reject(${r.id})">✖</button>
      </td>
    </tr>`;
  });

  document.getElementById("userTable").innerHTML=user;
  document.getElementById("adminTable").innerHTML=admin;

  updateTelegram();
}

function updateTelegram(){
  if(!requests.length)return;

  let r=requests[requests.length-1];

  let msg=encodeURIComponent(
`Activation Request

ID: ${r.id}
Plan: ${r.plan}
Status: ${r.status}

Requesting payment method:
(Zelle / Apple Pay / CashApp / Venmo / PayPal / Chime / Gift Card / Crypto)`
  );

  document.getElementById("telegramBtn").href=
  `https://t.me/hacyberglobaltech?text=${msg}`;
}

function openPayment(){
  document.getElementById("paymentModal").style.display="flex";
}

function closePayment(){
  document.getElementById("paymentModal").style.display="none";
}

function copyWallet(){
  navigator.clipboard.writeText(document.getElementById("wallet").innerText);
}

function toggleDashboard(){
  document.getElementById("dashboard").classList.toggle("active");
  render();
}

function scrollToPricing(){
  document.getElementById("pricing").scrollIntoView();
}

render();
</script>

</body>
</html>